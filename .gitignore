# Visual Studio / IDE droppings
.vs/
.vscode/
KameoRePowered.code-workspace

# Build output
/out/
*.pdb
*.ilk
*.exp
*.lib
*.exe

# rexglue migration backups
CMakeLists.txt.bak
src/main.cpp.bak

# Generated recomp sources
/generated/

# Runtime artifacts — binary, logs, and bundled shared libraries
/sdk/
/logs/
kameorepowered
kameorepowered.exe
kameorepowered.pdb
kameorepowered.toml
/*.so
/*.dll

# Game assets extracted from the user's ISO
# (the ISO itself and anything derived from it must NEVER be committed)
/kameo.iso
/assets/
!/assets/.gitkeep
/out/iso_extract/

# Title-update packages and anything extracted from them (copyrighted; the user
# supplies their own — see scripts/extract_tu.py)
/TU_*
/tu_extracted/
*.xexp

# Python caches
__pycache__/

# Derived title-update codegen config/manifest (generated by build.py --tu)
/.tu_config.toml
/.tu_build.toml

# Third-party tools dropped by the user locally.
# Ignore the tree, but keep the scripts and README we wrote.
/tools/*
!/tools/README.md
!/tools/*.ps1

# Locally built libraries
/local/
